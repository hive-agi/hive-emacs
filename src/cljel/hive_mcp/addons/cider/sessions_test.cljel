(ns hive-mcp-cider-sessions-test
  "ERT contract tests for the named CIDER session registry."
  (:require [cl-lib]))

(require 'ert)
(require 'hive-mcp-cider-sessions)

(ert-deftest hive-mcp-cider-sessions-test-register-validates-name nil
  "Session names must be non-nil strings."
  (hive-mcp-cider-sessions-clear-all)
  (unwind-protect
      (progn
        (should-error (hive-mcp-cider-sessions-register nil (list :port 1)))
        (should-error (hive-mcp-cider-sessions-register 42 (list :port 1))))
    (hive-mcp-cider-sessions-clear-all)))

(ert-deftest hive-mcp-cider-sessions-test-nil-props-still-exists nil
  "A stored nil value still occupies its session name."
  (hive-mcp-cider-sessions-clear-all)
  (unwind-protect
      (progn
        (hive-mcp-cider-sessions-register "nil-props" nil)
        (should (hive-mcp-cider-sessions-exists-p "nil-props"))
        (should-error (hive-mcp-cider-sessions-register "nil-props" nil)))
    (hive-mcp-cider-sessions-clear-all)))

(ert-deftest hive-mcp-cider-sessions-test-list-defaults nil
  "Missing enum fields serialize to stable API defaults."
  (hive-mcp-cider-sessions-clear-all)
  (unwind-protect
      (progn
        (hive-mcp-cider-sessions-register "minimal" (list :port 7920))
        (let* [listed (hive-mcp-cider-sessions-list-all)
               session (aref listed 0)]
          (should (equal "minimal" (plist-get session :name)))
          (should (equal "clj" (plist-get session :repl-type)))
          (should (equal "unknown" (plist-get session :status)))))
    (hive-mcp-cider-sessions-clear-all)))

(ert-deftest hive-mcp-cider-sessions-test-find-ignores-invalid-name nil
  "Status lookup ignores a legacy nil-key entry and returns a named session."
  (hive-mcp-cider-sessions-clear-all)
  (unwind-protect
      (progn
        (puthash nil (list :status 'connected)
                 hive-mcp-cider-sessions--registry)
        (puthash 42 (list :status 'connected)
                 hive-mcp-cider-sessions--registry)
        (hive-mcp-cider-sessions-register
         "real" (list :status 'connected :port 7921))
        (should (equal "real"
                       (hive-mcp-cider-sessions-find-by-status 'connected))))
    (hive-mcp-cider-sessions-clear-all)))

(ert-deftest hive-mcp-cider-sessions-test-list-excludes-invalid-name nil
  "Listing omits legacy entries whose names violate the registry contract."
  (hive-mcp-cider-sessions-clear-all)
  (unwind-protect
      (progn
        (puthash nil (list :status 'connected)
                 hive-mcp-cider-sessions--registry)
        (puthash 42 (list :status 'connected)
                 hive-mcp-cider-sessions--registry)
        (hive-mcp-cider-sessions-register
         "real" (list :status 'connected :port 7921))
        (let [listed (hive-mcp-cider-sessions-list-all)]
          (should (= 1 (length listed)))
          (should (equal "real" (plist-get (aref listed 0) :name)))))
    (hive-mcp-cider-sessions-clear-all)))

(defn run-tests []
  "Run all named-session registry ERT tests in batch."
  (interactive)
  (ert-run-tests-batch-and-exit "^hive-mcp-cider-sessions-test-"))
