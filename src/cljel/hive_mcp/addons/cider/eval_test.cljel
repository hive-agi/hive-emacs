(ns hive-mcp-cider-eval-test
  "ERT tests for the CIDER async eval state machine (hive-mcp-cider-eval).

Authored in cljel (dogfoods the compiler) and run against the SHIPPED compiled
module elisp/hive-mcp-cider-eval.el.

Run:
  emacs -batch -L elisp -L src/cljel/hive_mcp/addons/cider \\
        -l ert -l eval_test.el -f ert-run-tests-batch-and-exit

Each nREPL response is mocked as a string-keyed alist of (key . value) conses;
apply-response is pure w.r.t. its ST vector, so the machine is driven with no
live nREPL. ST layout is [value err out compiled state]."
  (:require [cl-lib]))

(require 'ert)
(require 'hive-mcp-cider-eval)

;; ============================================================================
;; Mock: nrepl-dict-get over a plain (key . value) alist
;; ============================================================================

(defun nrepl-dict-get (d k)
  "Test shim: look up string key K in alist D of (key . value) conses."
  (let [hit nil
        cur d]
    (while (and cur (not hit))
      (when (equal (car (car cur)) k)
        (setq hit (car cur)))
      (setq cur (cdr cur)))
    (cdr hit)))

;; ============================================================================
;; make-eval-state
;; ============================================================================

(ert-deftest hive-mcp-cider-eval-test-make-eval-state-fresh nil
  "A fresh eval-state is a 5-slot all-nil vector."
  (let [st (hive-mcp-cider-eval-make-eval-state)]
    (should (= 5 (length st)))
    (should-not (aref st 0))
    (should-not (aref st 1))
    (should-not (aref st 2))
    (should-not (aref st 3))
    (should-not (aref st 4))))

;; ============================================================================
;; apply-response — folding nREPL responses into the state vector
;; ============================================================================

(ert-deftest hive-mcp-cider-eval-test-apply-value-and-done nil
  "A value + done status lands in slot 0 and marks the state done (non-error)."
  (let [st (hive-mcp-cider-eval-make-eval-state)]
    (hive-mcp-cider-eval-apply-response
     st (list (cons "value" "42") (cons "status" (list "done"))))
    (should (equal "42" (aref st 0)))
    (should (aref st 4))
    (should-not (eq (aref st 4) 'error))))

(ert-deftest hive-mcp-cider-eval-test-apply-accumulates-out nil
  "stdout chunks accumulate across responses (str-concat into slot 2)."
  (let [st (hive-mcp-cider-eval-make-eval-state)]
    (hive-mcp-cider-eval-apply-response st (list (cons "out" "foo")))
    (hive-mcp-cider-eval-apply-response
     st (list (cons "out" "bar") (cons "status" (list "done"))))
    (should (equal "foobar" (aref st 2)))
    (should (aref st 4))))

(ert-deftest hive-mcp-cider-eval-test-apply-stderr-is-not-error nil
  "A plain stderr write with a done status is SUCCESS, not an eval error."
  (let [st (hive-mcp-cider-eval-make-eval-state)]
    (hive-mcp-cider-eval-apply-response
     st (list (cons "err" "a warning") (cons "status" (list "done"))))
    (should (equal "a warning" (aref st 1)))
    (should (aref st 4))
    (should-not (eq (aref st 4) 'error))))

(ert-deftest hive-mcp-cider-eval-test-apply-eval-error-status nil
  "An \"eval-error\" status marks the state 'error."
  (let [st (hive-mcp-cider-eval-make-eval-state)]
    (hive-mcp-cider-eval-apply-response
     st (list (cons "err" "boom") (cons "status" (list "eval-error" "done"))))
    (should (eq (aref st 4) 'error))))

(ert-deftest hive-mcp-cider-eval-test-apply-captures-compiled nil
  "A cljel-active session returns its result under cljel-compiled-elisp (slot 3)."
  (let [st (hive-mcp-cider-eval-make-eval-state)]
    (hive-mcp-cider-eval-apply-response
     st (list (cons "cljel-compiled-elisp" "(+ 1 2)") (cons "status" (list "done"))))
    (should (equal "(+ 1 2)" (aref st 3)))
    (should (aref st 4))))

;; ============================================================================
;; finalize-eval-state — turning a completed state into the result string
;; ============================================================================

(ert-deftest hive-mcp-cider-eval-test-finalize-plain-value nil
  "A plain clj value finalizes to itself."
  (let [st (hive-mcp-cider-eval-make-eval-state)]
    (hive-mcp-cider-eval-apply-response
     st (list (cons "value" "99") (cons "status" (list "done"))))
    (should (equal "99" (hive-mcp-cider-eval-finalize-eval-state st)))))

(ert-deftest hive-mcp-cider-eval-test-finalize-prepends-stdout nil
  "value + accumulated stdout finalizes to out-then-value."
  (let [st (hive-mcp-cider-eval-make-eval-state)]
    (hive-mcp-cider-eval-apply-response st (list (cons "out" "log:")))
    (hive-mcp-cider-eval-apply-response
     st (list (cons "value" "7") (cons "status" (list "done"))))
    (should (equal "log:7" (hive-mcp-cider-eval-finalize-eval-state st)))))

(ert-deftest hive-mcp-cider-eval-test-finalize-error-returns-stderr nil
  "An error state finalizes to the accumulated stderr."
  (let [st (hive-mcp-cider-eval-make-eval-state)]
    (hive-mcp-cider-eval-apply-response
     st (list (cons "err" "boom") (cons "status" (list "eval-error" "done"))))
    (should (equal "boom" (hive-mcp-cider-eval-finalize-eval-state st)))))

(ert-deftest hive-mcp-cider-eval-test-finalize-out-only nil
  "stdout with no value finalizes to the stdout."
  (let [st (hive-mcp-cider-eval-make-eval-state)]
    (hive-mcp-cider-eval-apply-response
     st (list (cons "out" "printed") (cons "status" (list "done"))))
    (should (equal "printed" (hive-mcp-cider-eval-finalize-eval-state st)))))

(ert-deftest hive-mcp-cider-eval-test-finalize-empty-is-nil-string nil
  "A bare done with no value/out/compiled finalizes to the string \"nil\"."
  (let [st (hive-mcp-cider-eval-make-eval-state)]
    (hive-mcp-cider-eval-apply-response st (list (cons "status" (list "done"))))
    (should (equal "nil" (hive-mcp-cider-eval-finalize-eval-state st)))))

;; --- The P0 regression: cljel-active result must EXECUTE locally, not be "nil" ---

(ert-deftest hive-mcp-cider-eval-test-finalize-compiled-executes-locally nil
  "cljel-compiled-elisp is executed in Emacs and its result returned.
Guards the P0 bug where a cljel-active eval silently returned \"nil\".
This branch runs when the cider-cljel client helper is absent (batch harness)."
  (let [st (hive-mcp-cider-eval-make-eval-state)]
    (hive-mcp-cider-eval-apply-response
     st (list (cons "cljel-compiled-elisp" "(+ 1 2)") (cons "status" (list "done"))))
    (should (equal "3" (hive-mcp-cider-eval-finalize-eval-state st)))))

(ert-deftest hive-mcp-cider-eval-test-finalize-compiled-delegates-to-helper nil
  "When the cider-cljel client helper is bound, finalize delegates to it."
  (let [st (hive-mcp-cider-eval-make-eval-state)]
    (hive-mcp-cider-eval-apply-response
     st (list (cons "cljel-compiled-elisp" "(ignored)") (cons "status" (list "done"))))
    (cl-letf (((symbol-function 'cider-cljel--eval-elisp-string)
               (lambda (s) (format "DELEGATED:%s" s))))
      (should (equal "DELEGATED:(ignored)"
                     (hive-mcp-cider-eval-finalize-eval-state st))))))

;; ============================================================================
;; Runner
;; ============================================================================

(defn run-tests []
  "Run all hive-mcp-cider-eval ERT tests in batch."
  (interactive)
  (ert-run-tests-batch-and-exit "^hive-mcp-cider-eval-test-"))

