(ns hive-mcp-cider-eval
  "CIDER nREPL evaluation with heartbeat polling and local CLJEL execution.")

(require 'cl-lib)

;; Dependencies on sibling modules
(declare-function hive-mcp-cider-sessions-lookup "hive-mcp-cider-sessions")
(declare-function hive-mcp-cider-sessions-update-prop "hive-mcp-cider-sessions")
(declare-function hive-mcp-cider-connection-ensure-connected "hive-mcp-cider-connection")

;; Dependencies on CIDER
(declare-function cider-nrepl-request:eval "cider-client")
(declare-function cider-interactive-eval "cider-eval")
(declare-function nrepl-dict-get "nrepl-dict")

;; ============================================================================
;; Configuration
;; ============================================================================

(defcustom hive-mcp-cider-eval-timeout 60
  "Timeout in seconds for nREPL evaluation with heartbeat polling."
  :type 'integer
  :group 'hive-mcp-cider)

(defcustom hive-mcp-cider-eval-poll-interval 0.1
  "Interval in seconds between heartbeat polls during async eval.
Smaller values = more responsive, larger values = less CPU overhead."
  :type 'number
  :group 'hive-mcp-cider)

;; ============================================================================
;; Core Eval Engine
;; ============================================================================

;; Eval state layout: [value err out compiled state]. STATE values:
;;   nil     -- still waiting
;;   t       -- done, success
;;   'error  -- done, evaluation error
(defn make-eval-state []
  "Create a fresh eval-state vector: [value err out compiled state]."
  (make-vector 5 nil))

(defn response-error-p [status ex root-ex]
  "Return non-nil when nREPL response fields indicate evaluation failure."
  (or ex root-ex (member "eval-error" status)))

(defn apply-response [st response]
  "Fold one nREPL RESPONSE dict into eval-state vector ST; mutate and return ST.

`err' and `out' accumulate across chunks. A plain stderr write does not mark
the response failed; `eval-error', `ex', or `root-ex' does. Compiled CLJEL is
stored for local execution by `finalize-eval-state'."
  (let [value (nrepl-dict-get response "value")
        err (nrepl-dict-get response "err")
        out (nrepl-dict-get response "out")
        compiled (nrepl-dict-get response "cljel-compiled-elisp")
        ex (nrepl-dict-get response "ex")
        root-ex (nrepl-dict-get response "root-ex")
        status (nrepl-dict-get response "status")]
    (when value
      (aset st 0 value))
    (when err
      (aset st 1 (str (or (aref st 1) "") err)))
    (when out
      (aset st 2 (str (or (aref st 2) "") out)))
    (when compiled
      (aset st 3 compiled))
    (when (and (not err) (or root-ex ex))
      (aset st 1 (str (or (aref st 1) "") (or root-ex ex))))
    (when (response-error-p status ex root-ex)
      (aset st 4 'error))
    (when (member "done" status)
      (unless (aref st 4)
        (aset st 4 t)))
    st))

(defn- execute-compiled-elisp [compiled]
  "Execute one compiled Elisp form and return its printed result."
  (condition-case e
      (progn
        (unless (stringp compiled)
          (error "Invalid compiled Elisp payload: %S" compiled))
        (ignore-errors (require 'clojure-elisp-runtime nil t))
        (if (fboundp 'cider-cljel--eval-elisp-string)
            (cider-cljel--eval-elisp-string compiled)
          (let* [read-result (read-from-string compiled)
                 form (car read-result)
                 tail (substring compiled (cdr read-result))]
            (when (string-match-p "[^[:space:]]" tail)
              (error "Compiled Elisp contains trailing forms"))
            (format "%S" (eval form t)))))
    (error (format "cljel client eval error: %S" e))))

(defn finalize-eval-state [st]
  "Compute the final result string from a completed eval-state ST.

Compiled Elisp delegates to the cider-cljel client helper when present, else
executes directly. Plain clj output precedes its value."
  (let [value (aref st 0)
        err (aref st 1)
        out (aref st 2)
        compiled (aref st 3)
        state (aref st 4)]
    (elisp-cond
     ((eq state 'error)
      (or err "Eval error"))
     (compiled
      (execute-compiled-elisp compiled))
     ((and value out (not (string= "" out)))
      (str out value))
     (value value)
     ((and out (not (string= "" out)))
      out)
     (t "nil"))))

(defn eval-with-heartbeat [code &optional timeout-override]
  "Evaluate CODE asynchronously with heartbeat polling.
Optional TIMEOUT-OVERRIDE in seconds (default: `hive-mcp-cider-eval-timeout').
Returns result string when ready or signals error on timeout.

Async state lives in a closure-local eval-state vector (see `make-eval-state');
the callback folds each nREPL response into it via `apply-response', and
`finalize-eval-state' turns the completed state into the result string —
executing compiled cljel locally in Emacs when the session is cljel-active."
  (let [st (make-eval-state)]
    ;; Send async request — callback folds responses into the local state
    (cider-nrepl-request:eval
     code
     (lambda (response)
       (apply-response st response)))
    ;; Poll with heartbeat until done or timeout
    (let [start-time (float-time)
          timeout (or timeout-override hive-mcp-cider-eval-timeout)
          interval hive-mcp-cider-eval-poll-interval]
      (while (and (not (aref st 4))
                  (< (- (float-time) start-time) timeout))
        (accept-process-output nil interval))
      (if (not (aref st 4))
          (error "Eval timed out after %d seconds (heartbeat polling)" timeout)
        (finalize-eval-state st)))))

;; ============================================================================
;; Session-Routed Eval
;; ============================================================================

(defn eval-in-session [name code &optional timeout]
  "Evaluate CODE in the CIDER session NAME.
Optional TIMEOUT in seconds (default: `hive-mcp-cider-eval-timeout').
Uses async evaluation with heartbeat polling."
  (let* [session (hive-mcp-cider-sessions-lookup name)
         cider-buf (plist-get session :cider-buffer)]
    (unless session
      (error "Session '%s' not found" name))
    (unless (eq (plist-get session :status) 'connected)
      (error "Session '%s' not connected (status: %s)"
             name (plist-get session :status)))
    (unless (and cider-buf (buffer-live-p (get-buffer cider-buf)))
      (ignore-errors
        (hive-mcp-cider-sessions-update-prop name :status 'stale))
      (error "Session '%s' REPL buffer is gone" name))
    (with-current-buffer cider-buf
      (eval-with-heartbeat code timeout))))

;; ============================================================================
;; MCP API Eval Functions
;; ============================================================================

(defn eval-silent [code &optional timeout]
  "Evaluate CODE via CIDER silently, return result.
Optional TIMEOUT in seconds.
Auto-connects if not connected, reusing existing session if available."
  (unless (hive-mcp-cider-connection-ensure-connected)
    (error "CIDER could not connect - no nREPL available"))
  (eval-with-heartbeat code timeout))

(defn eval-explicit [code]
  "Evaluate CODE via CIDER interactively.
Shows output in REPL buffer for collaborative debugging.
Auto-connects if not connected."
  (unless (hive-mcp-cider-connection-ensure-connected)
    (error "CIDER could not connect - no nREPL available"))
  (cider-interactive-eval code)
  (format "Sent to REPL: %s" (truncate-string-to-width code 50 nil nil "...")))
