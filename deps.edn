{:paths ["src" "resources" "elisp"]

 :deps {org.clojure/clojure {:mvn/version "1.12.1"}
        com.taoensso/timbre {:mvn/version "6.8.0"}

        ;; DataScript for daemon store (DaemonDS)
        datascript/datascript {:mvn/version "1.7.8"}
        org.replikativ/persistent-sorted-set {:mvn/version "0.4.122"}

        ;; hive-dsl — Result monad, rescue/guard DSL
        io.github.hive-agi/hive-dsl
        {:git/tag "v0.4.1" :git/sha "07ab02a16fc67ef6ca65a0c8f23b3cb322811649"}

        ;; hive-di — typed env var resolution with ADT backing (defconfig)
        io.github.hive-agi/hive-di
        {:git/tag "v0.3.1" :git/sha "ab63fd0"}

        ;; Process execution for emacsclient subprocess
        babashka/process {:mvn/version "0.6.25"}}

 :aliases
 {:test
  {:extra-paths ["test"]
   :extra-deps {io.github.cognitect-labs/test-runner
                {:git/tag "v0.5.1" :git/sha "dfb30dd"}
                org.clojure/test.check {:mvn/version "1.1.1"}}
   :main-opts ["-m" "cognitect.test-runner"]}}}
