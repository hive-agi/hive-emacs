  (interactive)
  (when olympus-ui--refresh-timer
    (cancel-timer olympus-ui--refresh-timer)
    (setq olympus-ui--refresh-timer nil))
  (when-let ((buf (get-buffer olympus-ui--buffer-name)))
    (delete-windows-on buf)))

