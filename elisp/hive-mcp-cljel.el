(defun hive-mcp-cljel--on-connected ()
  "Hook run when CIDER connects. Activates cljel session if pending."
  (when hive-mcp-cljel--pending-activation
    (setq hive-mcp-cljel--pending-activation nil)
    (let* ((repl-buf (current-buffer)))
    (setq hive-mcp-cljel--repl-buffer repl-buf)
    (when (fboundp 'cider-cljel-start)
    (run-at-time 1.0 nil (lambda ()
    (with-current-buffer repl-buf
    (cider-cljel-start)))))
    (advice-add 'cider-cljel-eval :around 'hive-mcp-cljel--route-eval)
    (when hive-mcp-cljel-auto-mode
    (run-at-time 2.0 nil 'hive-mcp-cljel--enable-cljel-buffers)))
    (message "ClojureElisp: session ready")))

(defun hive-mcp-cljel--enable-cljel-buffers ()
  "Enable cider-cljel-mode in all open .cljel buffers."
  (when (fboundp 'cider-cljel-mode)
    (dolist (buf (buffer-list))
    (with-current-buffer buf
    (when (and buffer-file-name (string-suffix-p ".cljel" buffer-file-name))
    (unless cider-cljel-mode
    (cider-cljel-mode 1)))))))

(defun hive-mcp-cljel--cljel-file-hook ()
  "Hook for clojure-mode to auto-enable cider-cljel-mode in .cljel files."
  (when (and buffer-file-name (string-suffix-p ".cljel" buffer-file-name) (featurep 'cider-clojure-elisp) (cider-connected-p) (fboundp 'cider-cljel-mode))
    (cider-cljel-mode 1)))

(defun hive-mcp-cljel--route-eval (orig-fn code)
  "Advice to route cider-cljel-eval through the cljel REPL buffer.\nEnsures eval goes to the clojure-elisp connection, not the default one."
  (if (and hive-mcp-cljel--repl-buffer (buffer-live-p hive-mcp-cljel--repl-buffer)) (with-current-buffer hive-mcp-cljel--repl-buffer
    (funcall orig-fn code)) (funcall orig-fn code)))

