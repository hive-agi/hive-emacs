  (message "hive-mcp-cljel: ready — use M-x cider-jack-in-cljel"))

(defun hive-mcp-cljel--addon-shutdown ()
  "Shutdown ClojureElisp addon."
  (remove-hook 'cider-connected-hook 'hive-mcp-cljel--on-connected)
